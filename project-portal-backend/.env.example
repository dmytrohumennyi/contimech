# Server
PORT=8080
NODE_ENV=production
PUBLIC_API_BASE=https://projects.contimech.org
ALLOWED_ORIGIN=https://contimech.org

# Session
SESSION_SECRET=replace_with_a_long_random_secret
# Optional. Leave empty for a host-only cookie on projects.contimech.org.
# COOKIE_DOMAIN=.contimech.org

# Password
# Generate with: npm run hash-password -- 'your-strong-password'
PROJECT_PORTAL_PASSWORD_HASH=$2a$12$replace_with_real_bcrypt_hash

# Project metadata
PROJECTS_FILE=./projects.json

# Storage option A: AWS S3 private bucket
AWS_REGION=eu-central-1
S3_BUCKET=contimech-project-materials

# Storage option B: local private files, useful for local tests
LOCAL_PROJECT_DIR=./private-project-slides
